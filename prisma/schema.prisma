// prisma/schema.prisma
// VYV Fleet Manager — Harmonie Ambulance
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  IMMOBILIZED
  SOLD
}

enum Energy {
  DIESEL
  HYBRID
  ELECTRIC
  GASOLINE
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  REGULATORY
  SANITAIRE
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum IncidentType {
  ACCIDENT
  THEFT
  VANDALISM
  BREAKDOWN
}

enum IncidentSeverity {
  CRITICAL
  MAJOR
  MINOR
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum FuelType {
  DIESEL
  HYBRID
  ELECTRIC
}

enum EquipmentCategory {
  STRETCHER
  DEFIBRILLATOR
  OXYGEN
  RADIO
  GPS
  FIRST_AID
  OTHER
}

enum EquipmentStatus {
  OK
  WARNING
  CRITICAL
  OUT_OF_SERVICE
}

enum AlertSeverity {
  CRITICAL
  WARNING
  INFO
}

enum AlertStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum AlertCategory {
  ARS
  CT
  ASSURANCE
  EQUIPEMENT
  MAINTENANCE
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  AGENCY_MANAGER
  STANDARD
}

enum PermissionAction {
  view
  create
  edit
  delete
}

enum AppModule {
  dashboard
  vehicles
  maintenance
  compliance
  incidents
  drivers
  fuel
  equipment
  settings
  finance
  substitutions
  relais
}

// ─────────────────────────────────────────────────────────────────
// AGENCY — Agences ambulancières
// ─────────────────────────────────────────────────────────────────

model Agency {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String
  city      String
  zipCode   String
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users              UserAgency[]
  vehicles           Vehicle[]
  drivers            Driver[]
  maintenances       Maintenance[]
  incidents          Incident[]
  equipment          Equipment[]
  fuelEntries        FuelEntry[]
  alerts             Alert[]
  complianceScores        ComplianceScore[]
  substitutionsIncoming   VehicleSubstitution[] @relation("SubstitutionIncomingAgency")

  @@index([isActive])
  relaisDepots    RelaisDepot[]

  @@map("agencies")
}

// ─────────────────────────────────────────────────────────────────
// ROLE & PERMISSIONS
// ─────────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  color       String   @default("gray")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  permissions Permission[]

  @@map("roles")
}

model Permission {
  id      String           @id @default(cuid())
  module  AppModule
  action  PermissionAction
  roleId  String

  role    Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, action])
  @@index([roleId])
  @@map("permissions")
}

// ─────────────────────────────────────────────────────────────────
// USER — Utilisateurs
// ─────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  firstName    String
  lastName     String
  email        String    @unique
  passwordHash String
  roleId       String
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  deletedAt    DateTime? // soft delete
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  role         Role         @relation(fields: [roleId], references: [id])
  agencies     UserAgency[]
  refreshTokens        RefreshToken[]
  substitutionsCreated VehicleSubstitution[] @relation("SubstitutionCreatedBy")

  @@index([email])
  @@index([roleId])
  @@index([deletedAt])
  relaisMissions      RelaisMission[] @relation("RelaisMissionCreatedBy")

  @@map("users")
}

// Table de jointure User <-> Agency (un user peut gérer plusieurs agences)
model UserAgency {
  userId    String
  agencyId  String

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency    Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@id([userId, agencyId])
  @@map("user_agencies")
}

// Refresh tokens JWT
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────
// VEHICLE — Véhicules
// ─────────────────────────────────────────────────────────────────

model Vehicle {
  id                        String          @id @default(cuid())
  registration              String          @unique // Immatriculation
  brand                     String
  model                     String
  categoryId                String
  category                  VehicleCategory @relation(fields: [categoryId], references: [id])
  energy                    Energy
  agencyId                  String
  mileage                   Int             @default(0)
  monthlyLeaseCost          Float?
  arsApprovalExpiry         DateTime?       // Agrément ARS
  insuranceExpiry           DateTime?
  technicalInspectionExpiry DateTime?       // Contrôle technique
  taxiMeterControlExpiry    DateTime?       // Prochain contrôle taximètre (Taxi uniquement)
  nextMaintenanceDate       DateTime?
  complianceScore           Int             @default(100)
  status                    VehicleStatus   @default(ACTIVE)
  isRelais                  Boolean         @default(false)  // Vehicule de remplacement temporaire
  firstRegistrationDate     DateTime?       // 1ere immatriculation (carte grise)
  entryDate                 DateTime?       // Entree dans le parc
  exitDate                  DateTime?       // Sortie du parc
  
  color                     String?         // Couleur du vehicule
  vin                       String?         // Numero de serie VIN
  nationalGenre             String?         // Genre national
  co2Emission               Float?          // Emission CO2 g/km
  seatingCapacity           Int?            // Nombre de places
  imeiPda                   String?         // IMEI du PDA
  imeiTelematics            String?         // IMEI du boitier telematique
  deletedAt                 DateTime?       // soft delete
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  // Relations
  agency       Agency        @relation(fields: [agencyId], references: [id])
  maintenances Maintenance[]
  incidents    Incident[]
  equipment    Equipment[]
  fuelEntries  FuelEntry[]
  tco          TCOEntry?
  alerts       Alert[]

  @@index([agencyId])
  @@index([status])
  @@index([categoryId])
  @@index([deletedAt])
  @@index([insuranceExpiry])
  @@index([technicalInspectionExpiry])
  contracts               VehicleContract[]
  amortizations           Amortization[]
  maintenanceAssignments  MaintenanceAssignment[]
  substitutionsIncoming   VehicleSubstitution[] @relation("SubstitutionIncoming")
  substitutionsOutgoing   VehicleSubstitution[] @relation("SubstitutionOutgoing")

  relaisDepotId            String?
  relaisDepot              RelaisDepot?    @relation("RelaisVehicleDepot", fields: [relaisDepotId], references: [id])
  relaisMissions           RelaisMission[] @relation("RelaisVehicle")
  relaisReplacedMissions   RelaisMission[] @relation("ReplacedVehicle")

  @@map("vehicles")
}

// ─────────────────────────────────────────────────────────────────
// DRIVER — Conducteurs
// ─────────────────────────────────────────────────────────────────

model Driver {
  id                String    @id @default(cuid())
  firstName         String
  lastName          String
  email             String?
  phone             String?
  role              String    // "Ambulancier" | "Auxiliaire ambulancier"
  agencyId          String
  status            String    @default("ACTIVE") // ACTIVE | SUSPENDED | LEAVE | INACTIVE
  licenseNumber     String?
  licenseExpiry     DateTime?
  medicalExamDate   DateTime?
  medicalExamExpiry DateTime?
  deletedAt         DateTime? // soft delete
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Champs étendus
  address                  String?
  contractType             String?   // CDI | CDD | INTERIM | OTHER
  deaExpiry                DateTime?
  fspExpiry                DateTime?
  medicalCertificateExpiry DateTime?
  nextTrainingDate         DateTime?
  totalMileage             Int       @default(0)

  // Relations
  agency         Agency               @relation(fields: [agencyId], references: [id])
  incidents      DriverIncident[]
  habilitations  DriverHabilitation[]
  alerts         Alert[]

  @@index([agencyId])
  @@index([status])
  @@index([deletedAt])
  @@map("drivers")
}

// ─────────────────────────────────────────────────────────────────
// MAINTENANCE — Interventions de maintenance
// ─────────────────────────────────────────────────────────────────

model Maintenance {
  id                   String            @id @default(cuid())
  vehicleId            String
  agencyId             String
  type                 MaintenanceType
  label                String
  description          String?
  scheduledDate        DateTime
  completedDate        DateTime?
  status               MaintenanceStatus @default(SCHEDULED)
  provider             String?
  estimatedCost        Float?
  realCost             Float?
  mileageAtMaintenance Int?
  notes                String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  // Relations
  vehicle  Vehicle @relation(fields: [vehicleId], references: [id])
  agency   Agency  @relation(fields: [agencyId], references: [id])

  @@index([vehicleId])
  @@index([agencyId])
  @@index([status])
  @@index([scheduledDate])
  @@index([type])
  @@map("maintenances")
}

// ─────────────────────────────────────────────────────────────────
// INCIDENT — Sinistres
// ─────────────────────────────────────────────────────────────────

model Incident {
  id                   String           @id @default(cuid())
  vehicleId            String
  agencyId             String
  date                 DateTime
  declarationDate      DateTime
  type                 IncidentType
  severity             IncidentSeverity
  status               IncidentStatus   @default(OPEN)
  description          String
  location             String
  driverResponsible    Boolean          @default(false)
  injuredPersons       Int              @default(0)
  patientInVehicle     Boolean          @default(false)
  thirdPartyInvolved   Boolean          @default(false)
  thirdPartyInsurance  String?
  insuranceReference   String?
  estimatedRepairCost  Float?
  realRepairCost       Float?
  immobilizationDays   Int?
  repairProvider       String?
  notes                String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  // Relations
  vehicle Vehicle          @relation(fields: [vehicleId], references: [id])
  agency  Agency           @relation(fields: [agencyId], references: [id])
  drivers DriverIncident[]

  @@index([vehicleId])
  @@index([agencyId])
  @@index([status])
  @@index([severity])
  @@index([date])
  @@map("incidents")
}

// Table de jointure Driver <-> Incident
model DriverIncident {
  driverId   String
  incidentId String

  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@id([driverId, incidentId])
  @@map("driver_incidents")
}

// ─────────────────────────────────────────────────────────────────
// EQUIPMENT — Équipements médicaux
// ─────────────────────────────────────────────────────────────────

model Equipment {
  id                  String            @id @default(cuid())
  vehicleId           String?
  agencyId            String
  label               String
  category            EquipmentCategory
  serialNumber        String?
  status              EquipmentStatus   @default(OK)
  installDate         DateTime?
  lastCheckDate       DateTime?
  nextCheckDate       DateTime?
  expiryDate          DateTime?
  maintenanceProvider String?
  notes               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  // Relations
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  agency  Agency  @relation(fields: [agencyId], references: [id])

  @@index([vehicleId])
  @@index([agencyId])
  @@index([status])
  @@index([category])
  @@index([nextCheckDate])
  @@map("equipment")
}

// ─────────────────────────────────────────────────────────────────
// FUEL ENTRY — Saisies carburant
// ─────────────────────────────────────────────────────────────────

model FuelEntry {
  id                 String   @id @default(cuid())
  vehicleId          String
  agencyId           String
  date               DateTime
  fuelType           FuelType
  liters             Float    @default(0)
  pricePerLiter      Float    @default(0)
  totalCost          Float
  mileageAtFill      Int
  distanceSinceLast  Int      @default(0)
  consumption        Float?   // L/100km, null pour électrique
  station            String?
  driverName         String?
  cardNumber         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  agency  Agency  @relation(fields: [agencyId], references: [id])

  @@index([vehicleId])
  @@index([agencyId])
  @@index([date])
  @@index([fuelType])
  @@map("fuel_entries")
}

// ─────────────────────────────────────────────────────────────────
// TCO ENTRY — Coût total de possession par véhicule
// ─────────────────────────────────────────────────────────────────

model TCOEntry {
  id                 String  @id @default(cuid())
  vehicleId          String  @unique
  agencyId           String
  monthlyLease       Float   @default(0)
  monthlyFuel        Float   @default(0)
  monthlyMaintenance Float   @default(0)
  monthlyInsurance   Float   @default(0)
  monthlyOther       Float   @default(0)
  totalMonthlyCost   Float   @default(0)
  annualCost         Float   @default(0)
  costPerKm          Float   @default(0)
  mileage            Int     @default(0)
  updatedAt          DateTime @updatedAt

  // Relations
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([agencyId])
  @@map("tco_entries")
}

// ─────────────────────────────────────────────────────────────────
// ALERT — Alertes de conformité
// ─────────────────────────────────────────────────────────────────

model Alert {
  id                  String        @id @default(cuid())
  vehicleId           String?
  driverId            String?
  agencyId            String
  type                String        // libellé libre : "Contrôle technique", "ARS", etc.
  category            AlertCategory
  severity            AlertSeverity
  status              AlertStatus   @default(OPEN)
  message             String
  description         String
  dueDate             DateTime?
  resolvedAt          DateTime?
  resolvedBy          String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  driver  Driver?  @relation(fields: [driverId],  references: [id])
  agency  Agency  @relation(fields: [agencyId], references: [id])

  @@index([vehicleId])
  @@index([agencyId])
  @@index([status])
  @@index([severity])
  @@index([category])
  @@index([driverId])
  @@map("alerts")
}

// ─────────────────────────────────────────────────────────────────
// COMPLIANCE SCORE — Score de conformité par agence
// ─────────────────────────────────────────────────────────────────

model ComplianceScore {
  id               String   @id @default(cuid())
  agencyId         String
  globalScore      Int      @default(100)
  arsScore         Int      @default(100)
  ctScore          Int      @default(100)
  insuranceScore   Int      @default(100)
  equipmentScore   Int      @default(100)
  openAlerts       Int      @default(0)
  criticalAlerts   Int      @default(0)
  resolvedAlerts   Int      @default(0)
  calculatedAt     DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  agency Agency @relation(fields: [agencyId], references: [id])

  @@index([agencyId])
  @@map("compliance_scores")
}

// ─────────────────────────────────────────────────────────────────
// APP SETTINGS — Configuration globale de l'application
// ─────────────────────────────────────────────────────────────────

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// CONTRATS DE FINANCEMENT VEHICULE

enum VehicleContractType {
  CREDIT_BAIL
  LOA
  LLD
  CREDIT_BANCAIRE
  EN_PROPRIETE
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

model VehicleContract {
  id                   String              @id @default(uuid())
  vehicleId            String
  vehicle              Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type                 VehicleContractType
  status               ContractStatus      @default(ACTIVE)
  isActive             Boolean             @default(true)
  lessorName           String              @default("")
  contractRef          String              @default("")
  startDate            DateTime
  endDate              DateTime?
  durationMonths       Int                 @default(0)
  monthlyRentHT        Float               @default(0)
  deposit              Float               @default(0)
  residualValue        Float?
  startMileage         Int?
  contractedKmPerYear  Int?
  contractedKmTotal    Int?
  excessKmCostPerKm    Float?
  monthlyInsuranceCost Float?
  includedServices     Json                @default("{\"maintenance\":false,\"tires\":false,\"insurance\":false,\"assistance\":false}")
  notes                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  @@index([vehicleId])
  @@map("vehicle_contracts")
}

// AMORTISSEMENTS

enum AmortizationSource {
  CREDIT_BAIL
  MAINTENANCE
}

enum AmortizationStatus {
  ACTIVE
  CLOSED
}

model Amortization {
  id             String             @id @default(uuid())
  vehicleId      String
  vehicle        Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  source         AmortizationSource
  sourceId       String
  reference      String
  label          String
  amount         Float
  startDate      DateTime
  durationMonths Int
  status         AmortizationStatus @default(ACTIVE)
  closedAt       DateTime?
  entries        Json               @default("[]")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  @@index([vehicleId])
  @@index([sourceId])
  @@map("amortizations")
}

// CATEGORIES DE VEHICULE (parametrables)

model VehicleCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  label     String
  color     String    @default("gray")
  vatRate   Float     @default(20)
  order     Int       @default(0)
  isActive  Boolean   @default(true)
  isSystem  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  vehicles  Vehicle[]

  @@map("vehicle_categories")
}

// TEMPLATES DE MAINTENANCE

enum MaintenanceTriggerType {
  TIME_ONLY
  KM_ONLY
  HYBRID
}

model MaintenanceTemplate {
  id                   String                    @id @default(cuid())
  name                 String
  description          String?
  type                 MaintenanceType
  triggerType          MaintenanceTriggerType
  triggerKm            Int?
  triggerDays          Int?
  estimatedCost        Float?
  applicableCategories String[]
  isMandatory          Boolean                   @default(false)
  checklist            MaintenanceChecklistItem[]
  assignments          MaintenanceAssignment[]
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@map("maintenance_templates")
}

model MaintenanceChecklistItem {
  id         String              @id @default(cuid())
  templateId String
  template   MaintenanceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  label      String
  order      Int                 @default(0)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([templateId])
  @@map("maintenance_checklist_items")
}

model MaintenanceAssignment {
  id              String              @id @default(cuid())
  vehicleId       String
  vehicle         Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  templateId      String
  template        MaintenanceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  isActive        Boolean             @default(true)
  lastDoneDate    DateTime?
  lastDoneMileage Int?
  nextDueDate     DateTime?
  nextDueMileage  Int?
  assignedAt      DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([vehicleId, templateId])
  @@index([vehicleId])
  @@index([templateId])
  @@map("maintenance_assignments")
}

// ─── Habilitations conducteurs ────────────────────────────────────────────────
model DriverHabilitation {
  id          String   @id @default(cuid())
  driverId    String
  type        String   // DEA | FSP | PERMIS | CERTIFICAT_MEDICAL | OTHER
  issuedDate  DateTime?
  expiryDate  DateTime?
  status      String   @default("VALID") // VALID | EXPIRED | PENDING
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([expiryDate])
  @@map("driver_habilitations")
}

// ─────────────────────────────────────────────────────────────────
// VEHICLE SUBSTITUTION — Mouvements de véhicules
// ─────────────────────────────────────────────────────────────────

enum SubstitutionStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum SubstitutionVehicleType {
  AMBULANCE
  VSL
  TAXI
  TPMR
  TRANSPORT_PERSONNES
}

model VehicleSubstitution {
  id            String   @id @default(cuid())
  effectiveDate DateTime

  // ── Véhicule entrant ──
  incomingVehicleId       String
  incomingVehicle         Vehicle  @relation("SubstitutionIncoming", fields: [incomingVehicleId], references: [id])
  incomingAgencyId        String
  incomingAgency          Agency   @relation("SubstitutionIncomingAgency", fields: [incomingAgencyId], references: [id])
  incomingAlias           String?
  incomingVehicleType     SubstitutionVehicleType
  incomingTaxiConventionAM Boolean @default(false)

  // Déclarations réglementaires (entrant)
  axaNotified             Boolean  @default(false)
  arsDeclaration          Boolean  @default(false)
  amsReceived             Boolean  @default(false)
  adsDeclaration          Boolean  @default(false)
  adsNumber               String?
  adsMunicipality         String?

  // ── Véhicule sortant ──
  outgoingVehicleId       String
  outgoingVehicle         Vehicle  @relation("SubstitutionOutgoing", fields: [outgoingVehicleId], references: [id])
  outgoingAlias           String?
  outgoingVehicleType     SubstitutionVehicleType
  outgoingMileage         Int

  // Équipements sortant (source de vérité)
  hasFuelCard             Boolean  @default(false)
  dkvReplacement          Boolean  @default(false)
  tollDevice              Boolean  @default(false)
  tollDeviceNumber        String?
  geolocDevice            Boolean  @default(false)
  geolocImei              String?
  pdaDevice               Boolean  @default(false)
  pdaImei                 String?

  // Transferts vers entrant (optionnels)
  incomingFuelCard        Boolean  @default(false)
  incomingDkv             Boolean  @default(false)
  incomingTollDevice      Boolean  @default(false)
  incomingGeolocDevice    Boolean  @default(false)
  incomingGeolocImei      String?
  incomingPdaDevice       Boolean  @default(false)
  incomingPdaImei         String?

  // État du véhicule sortant
  returnReportByEmail     Boolean  @default(false)
  returnReportDate        DateTime?
  bodyCondition           String?
  sanitaryCellCondition   String?
  interiorCondition       String?
  mechanicalCondition     String?
  additionalCosts         String?
  isDriveable             Boolean  @default(true)
  vehicleLocation         String?

  // Suivi
  status                  SubstitutionStatus @default(DRAFT)
  createdById             String
  createdBy               User     @relation("SubstitutionCreatedBy", fields: [createdById], references: [id])
  notes                   String?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([incomingVehicleId])
  @@index([outgoingVehicleId])
  @@index([incomingAgencyId])
  @@index([effectiveDate])
  @@index([status])
  @@map("vehicle_substitutions")
}

// ─────────────────────────────────────────────────────────────────
// RELAIS — Véhicules de remplacement temporaire
// ─────────────────────────────────────────────────────────────────

enum RelaisMissionStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

model RelaisDepot {
  id          String   @id @default(cuid())
  name        String
  address     String?
  city        String?
  zipCode     String?
  phone       String?
  capacity    Int      @default(1)
  agencyId    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agency      Agency?        @relation(fields: [agencyId], references: [id])
  vehicles    Vehicle[]      @relation("RelaisVehicleDepot")
  missions    RelaisMission[]

  @@index([agencyId])
  @@map("relais_depots")
}

model RelaisMission {
  id                String              @id @default(cuid())
  relaisVehicleId   String
  replacedVehicleId String
  depotId           String?
  startDate         DateTime
  estimatedEndDate  DateTime?
  endDate           DateTime?
  status            RelaisMissionStatus @default(PLANNED)
  reason            String?
  notes             String?
  createdById       String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  relaisVehicle     Vehicle  @relation("RelaisVehicle",   fields: [relaisVehicleId],   references: [id])
  replacedVehicle   Vehicle  @relation("ReplacedVehicle", fields: [replacedVehicleId], references: [id])
  depot             RelaisDepot? @relation(fields: [depotId], references: [id])
  createdBy         User     @relation("RelaisMissionCreatedBy", fields: [createdById], references: [id])

  @@index([relaisVehicleId])
  @@index([replacedVehicleId])
  @@index([status])
  @@index([startDate])
  @@map("relais_missions")
}

