{
  "name": "fleet-backend",
  "version": "1.0.0",
  "description": "VYV Fleet Manager — API Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "dotenv -e .env -- npx prisma migrate dev",
    "generate": "prisma generate",
    "seed": "tsx prisma/seed.ts",
    "studio": "prisma studio",
    "seed:alerts": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' -r dotenv/config prisma/seed-alerts.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.11.5",
    "prisma": "^7.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.7",
    "dotenv-cli": "^7.4.1",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5"
  }
}
